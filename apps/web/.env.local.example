# Auth.js – für Produktion/Entra erforderlich (siehe docs/INSTALLATION.md)
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# Delegierter Scope für die ValentinRSM-API (Expose an API in Entra):
# AUTH_API_SCOPE=api://<API_APP_ID>/access_as_user
# Zugang steuern Sie in Entra (Unternehmens-App / Zuweisungen), nicht in der App
# Lokal: Middleware ohne Login (API dann Auth:Mode=None)
# AUTH_DISABLED=true
