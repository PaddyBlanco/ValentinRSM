# Kopieren nach .env im Projektroot und Werte setzen ( .env ist gitignored ).
# Siehe docs/INSTALLATION.md (u. a. 4.4 Connection String, 4.5 Entra).

# --- SQL Server (Docker) ---
# SA-Passwort: SQL-Server-Komplexitätsregeln beachten. Wird für db + API-ConnectionString genutzt.
MSSQL_SA_PASSWORD=Change_Me_Strong_Passw0rd!

# --- Web: API vom Browser aus (Next.js Client) ---
# Standard-Compose: API auf Host-Port 8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: nur wenn ihr SSR/Server-Fetch im Web-Container anders routen müsst (Compose setzt api:8080 intern selbst).
# API_INTERNAL_URL=http://api:8080

# --- API (Compose-Service „api“): Entra-JWT ---
# Ohne Entra: nichts auskommentieren (Standard: AUTH_API_MODE=None laut docker-compose).
# Mit Entra: die nächsten Zeilen auskommentieren, Platzhalter ersetzen (Namen wie in docker-compose.yml).
# AUTH_API_MODE=Entra
# AZURE_AD_TENANT_ID=<Verzeichnis-ID>
# AZURE_AD_API_CLIENT_ID=<Anwendungs-ID „ValentinRSM API“>
# AZURE_AD_API_AUDIENCE=<meist api://… aus „API verfügbar machen“, siehe INSTALLATION>

# --- Web (Compose-Service „web“): Auth.js / Microsoft Entra ID ---
# AUTH_SECRET=<openssl rand -base64 32>
# AUTH_URL=http://localhost:3000
# AUTH_MICROSOFT_ENTRA_ID_ID=<Anwendungs-ID „ValentinRSM Web“>
# AUTH_MICROSOFT_ENTRA_ID_SECRET=<Clientgeheimnis: Spalte „Wert“>
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# AUTH_API_SCOPE=api://<API_CLIENT_ID>/access_as_user

# Nur Entwicklung ohne Microsoft-Login (API dann sinnvollerweise ohne Entra-Zeilen oben)
# AUTH_DISABLED=true

# Öffentlicher Deploy: AUTH_URL, NEXT_PUBLIC_API_URL, Entra-Redirect-URIs und ggf. CORS (AllowedOrigins) an die echte HTTPS-URL anpassen.
