# SQL Server (Docker) – SA-Passwort muss der Komplexitätsregel von SQL Server genügen.
MSSQL_SA_PASSWORD=Change_Me_Strong_Passw0rd!

# Öffentliche API-URL für den Browser (Next.js Client), wenn alles per Compose läuft:
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: Server-seitige API-URL im Web-Container (SSR / server fetch). In docker-compose.yml
# für Service "web" bereits gesetzt: http://api:8080
# API_INTERNAL_URL=http://api:8080
